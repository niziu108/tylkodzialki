generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                     @id @default(cuid())
  name                     String?
  email                    String?                    @unique
  emailVerified            DateTime?
  image                    String?
  passwordHash             String?
  role                     Role                       @default(USER)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  listingCredits           Int                        @default(0)
  listingCreditsExpiresAt  DateTime?
  featuredCredits          Int                        @default(0)
  featuredCreditsExpiresAt DateTime?
  accounts                 Account[]
  dzialki                  Dzialka[]
  emailSendLogs            EmailSendLog[]
  invoices                 Invoice[]
  creditTransactions       ListingCreditTransaction[]
  listingOrders            ListingOrder[]
  sessions                 Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dzialka {
  id               String            @id @default(cuid())
  tytul            String
  cenaPln          Int
  powierzchniaM2   Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  editToken        String            @unique
  email            String?
  expiresAt        DateTime?
  lat              Float?
  lng              Float?
  locationFull     String?
  locationLabel    String?
  locationMode     LocationMode      @default(EXACT)
  mapsUrl          String?
  parcelText       String?
  placeId          String?
  przeznaczenia    Przeznaczenie[]
  telefon          String
  klasaZiemi       String?
  ksiegaWieczysta  String?
  mpzp             Boolean           @default(false)
  projektDomu      Boolean           @default(false)
  wymiary          String?
  wzWydane         Boolean           @default(false)
  numerOferty      String?
  sprzedajacyTyp   SprzedajacyTyp    @default(PRYWATNIE)
  kanalizacja      KanalizacjaStatus @default(BRAK)
  gaz              GazStatus         @default(BRAK)
  swiatlowod       SwiatlowodStatus  @default(BRAK)
  prad             PradStatus        @default(BRAK_PRZYLACZA)
  woda             WodaStatus        @default(BRAK_PRZYLACZA)
  opis             String?
  ownerId          String?
  endedAt          DateTime?
  publishedAt      DateTime          @default(now())
  status           DzialkaStatus     @default(AKTYWNE)
  featuredUntil    DateTime?
  isFeatured       Boolean           @default(false)
  detailViewsCount Int               @default(0)
  viewsCount       Int               @default(0)
  owner            User?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  zdjecia          Zdjecie[]

  @@index([lat, lng])
  @@index([ownerId])
  @@index([status])
  @@index([expiresAt])
  @@index([isFeatured])
  @@index([featuredUntil])
}

model Zdjecie {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  kolejnosc Int      @default(0)
  dzialkaId String
  createdAt DateTime @default(now())
  dzialka   Dzialka  @relation(fields: [dzialkaId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model AppConfig {
  id                          String   @id @default(cuid())
  paymentsEnabled             Boolean  @default(false)
  freeListingCredits          Int      @default(0)
  freeListingCreditsDays      Int?

  listingSinglePriceGrossPln  Int      @default(1900)
  listingPack10PriceGrossPln  Int      @default(14900)
  listingPack40PriceGrossPln  Int      @default(39900)

  featuredSinglePriceGrossPln Int      @default(1900)
  featuredPack3PriceGrossPln  Int      @default(3900)

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model ListingCreditTransaction {
  id           String                  @id @default(cuid())
  userId       String
  delta        Int
  balanceAfter Int
  sourceType   ListingCreditSourceType
  note         String?
  expiresAt    DateTime?
  orderId      String?
  createdAt    DateTime                @default(now())
  order        ListingOrder?           @relation(fields: [orderId], references: [id])
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([sourceType])
}

model ListingOrder {
  id                    String                     @id @default(cuid())
  userId                String
  packageType           ListingPackageType
  packageName           String
  credits               Int
  validityDays          Int?
  amountGrossPln        Int
  currency              String                     @default("PLN")
  status                ListingPaymentStatus       @default(PENDING)
  stripeSessionId       String?                    @unique
  stripePaymentIntentId String?                    @unique
  paidAt                DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  featuredCredits       Int                        @default(0)
  buyerAddressLine1     String?
  buyerCity             String?
  buyerCompanyName      String?
  buyerEmail            String?
  buyerNip              String?
  buyerPostalCode       String?
  invoiceIssuedAt       DateTime?
  invoiceNumber         String?
  invoicePdfUrl         String?
  invoiceType           BuyerInvoiceType           @default(NONE)
  creditTransactions    ListingCreditTransaction[]
  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([packageType])
}

model Invoice {
  id                    String            @id @default(cuid())
  userId                String
  stripeSessionId       String?           @unique
  stripePaymentIntentId String?           @unique
  stripeCheckoutUrl     String?
  invoiceNumber         String?           @unique
  type                  SalesInvoiceType
  status                InvoiceStatus     @default(PENDING)
  source                InvoiceSource     @default(INTERNAL)
  amountGross           Int
  currency              String            @default("PLN")
  companyName           String?
  nip                   String?
  addressLine1          String?
  addressLine2          String?
  postalCode            String?
  city                  String?
  country               String?           @default("PL")
  invoiceEmail          String?
  itemName              String?
  quantity              Int               @default(1)
  issuedAt              DateTime?
  paidAt                DateTime?
  pdfPath               String?
  pdfFileName           String?
  ksefReferenceNumber   String?
  ksefInvoiceNumber     String?
  ksefSentAt            DateTime?
  ksefAcceptedAt        DateTime?
  ksefErrorMessage      String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  buyerName             String?
  ksefRequired          Boolean           @default(true)
  buyerType             InvoiceBuyerType?
  ksefStatus            KsefStatus        @default(READY)
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([buyerType, createdAt])
  @@index([ksefStatus, createdAt])
  @@index([invoiceNumber])
  @@index([nip])
}

model EmailSendLog {
  id          String        @id @default(cuid())
  type        EmailSendType
  campaignKey String
  email       String
  userId      String?
  sentAt      DateTime      @default(now())
  user        User?         @relation(fields: [userId], references: [id])

  @@unique([type, campaignKey, email])
  @@index([userId])
  @@index([campaignKey])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  imageUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished, createdAt])
}

enum Role {
  USER
  ADMIN
}

enum DzialkaStatus {
  AKTYWNE
  ZAKONCZONE
}

enum ListingCreditSourceType {
  MANUAL
  FREE
  PACKAGE_PURCHASE
  SINGLE_PURCHASE
  ADMIN_GRANT
  FEATURED_BONUS
  FEATURED_USAGE
}

enum ListingPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum ListingPackageType {
  SINGLE
  PACK_10
  PACK_40
}

enum BuyerInvoiceType {
  NONE
  COMPANY
}

enum InvoiceBuyerType {
  PRIVATE
  COMPANY
}

enum KsefStatus {
  READY
  SENT
  ACCEPTED
  ERROR
}

enum Przeznaczenie {
  BUDOWLANA
  USLUGOWA
  ROLNA
  LESNA
  INWESTYCYJNA
}

enum LocationMode {
  EXACT
  APPROX
}

enum SprzedajacyTyp {
  PRYWATNIE
  BIURO
}

enum PradStatus {
  BRAK_PRZYLACZA
  PRZYLACZE_NA_DZIALCE
  PRZYLACZE_W_DRODZE
  WARUNKI_PRZYLACZENIA_WYDANE
  MOZLIWOSC_PRZYLACZENIA
}

enum WodaStatus {
  BRAK_PRZYLACZA
  WODOCIAG_NA_DZIALCE
  WODOCIAG_W_DRODZE
  STUDNIA_GLEBINOWA
  MOZLIWOSC_PODLACZENIA
}

enum KanalizacjaStatus {
  BRAK
  MIEJSKA_NA_DZIALCE
  MIEJSKA_W_DRODZE
  SZAMBO
  PRZYDOMOWA_OCZYSZCZALNIA
  MOZLIWOSC_PODLACZENIA
}

enum GazStatus {
  BRAK
  GAZ_NA_DZIALCE
  GAZ_W_DRODZE
  MOZLIWOSC_PODLACZENIA
}

enum SwiatlowodStatus {
  BRAK
  W_DRODZE
  NA_DZIALCE
}

enum SalesInvoiceType {
  LISTING_PACKAGE
  FEATURED_PACKAGE
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum InvoiceSource {
  INTERNAL
  KSEF
}

enum EmailSendType {
  REMINDER
}