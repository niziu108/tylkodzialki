generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(cuid())
  name                     String?
  email                    String?   @unique
  emailVerified            DateTime?
  image                    String?
  passwordHash             String?
  role                     Role      @default(USER)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  listingCredits           Int       @default(0)
  listingCreditsExpiresAt  DateTime?
  featuredCredits          Int       @default(0)
  featuredCreditsExpiresAt DateTime?

  defaultTelefon         String?
  defaultSprzedajacyTyp  SprzedajacyTyp?
  defaultSprzedajacyImie String?
  defaultBiuroNazwa      String?
  defaultBiuroOpiekun    String?
  defaultBiuroLogoUrl    String?

  accounts           Account[]
  crmIntegrations    CrmIntegration[]
  creditTransactions ListingCreditTransaction[]
  dzialki            Dzialka[]
  emailSendLogs      EmailSendLog[]
  invoices           Invoice[]
  listingOrders      ListingOrder[]
  sessions           Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dzialka {
  id             String          @id @default(cuid())
  tytul          String
  cenaPln        Int
  powierzchniaM2 Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  editToken      String          @unique
  email          String?
  expiresAt      DateTime?
  lat            Float?
  lng            Float?
  locationFull   String?
  locationLabel  String?
  locationMode   LocationMode    @default(EXACT)
  mapsUrl        String?
  parcelText     String?
  placeId        String?
  przeznaczenia  Przeznaczenie[]
  telefon        String

  sprzedajacyImie String?
  biuroNazwa      String?
  biuroOpiekun    String?
  biuroLogoUrl    String?

  klasaZiemi       String?
  ksiegaWieczysta  String?
  mpzp             Boolean           @default(false)
  projektDomu      Boolean           @default(false)
  wymiary          String?
  wzWydane         Boolean           @default(false)
  numerOferty      String?
  sprzedajacyTyp   SprzedajacyTyp    @default(PRYWATNIE)
  kanalizacja      KanalizacjaStatus @default(BRAK)
  gaz              GazStatus         @default(BRAK)
  swiatlowod       SwiatlowodStatus  @default(BRAK)
  prad             PradStatus        @default(BRAK_PRZYLACZA)
  woda             WodaStatus        @default(BRAK_PRZYLACZA)
  opis             String?
  ownerId          String?
  endedAt          DateTime?
  publishedAt      DateTime          @default(now())
  status           DzialkaStatus     @default(AKTYWNE)
  featuredUntil    DateTime?
  isFeatured       Boolean           @default(false)
  detailViewsCount Int               @default(0)
  viewsCount       Int               @default(0)

  sourceType      DzialkaSourceType @default(MANUAL)
  crmImportedAt   DateTime?
  crmLastSyncedAt DateTime?

  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  crmOfferLinks CrmOfferLink[]
  crmSyncLogs   CrmSyncLog[]
  zdjecia       Zdjecie[]

  @@index([lat, lng])
  @@index([ownerId])
  @@index([status])
  @@index([expiresAt])
  @@index([isFeatured])
  @@index([featuredUntil])
  @@index([sourceType])
  @@index([crmLastSyncedAt])
}

model Zdjecie {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  kolejnosc Int      @default(0)
  dzialkaId String
  createdAt DateTime @default(now())
  dzialka   Dzialka  @relation(fields: [dzialkaId], references: [id], onDelete: Cascade)

  @@index([dzialkaId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model AppConfig {
  id                     String  @id @default(cuid())
  paymentsEnabled        Boolean @default(false)
  freeListingCredits     Int     @default(0)
  freeListingCreditsDays Int?

  listingSinglePriceGrossPln Int @default(1900)
  listingPack10PriceGrossPln Int @default(14900)
  listingPack40PriceGrossPln Int @default(39900)

  featuredSinglePriceGrossPln Int @default(1900)
  featuredPack3PriceGrossPln  Int @default(3900)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ListingCreditTransaction {
  id           String                  @id @default(cuid())
  userId       String
  delta        Int
  balanceAfter Int
  sourceType   ListingCreditSourceType
  note         String?
  expiresAt    DateTime?
  orderId      String?
  createdAt    DateTime                @default(now())
  order        ListingOrder?           @relation(fields: [orderId], references: [id])
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([sourceType])
}

model ListingOrder {
  id                    String                     @id @default(cuid())
  userId                String
  packageType           ListingPackageType
  packageName           String
  credits               Int
  validityDays          Int?
  amountGrossPln        Int
  currency              String                     @default("PLN")
  status                ListingPaymentStatus       @default(PENDING)
  stripeSessionId       String?                    @unique
  stripePaymentIntentId String?                    @unique
  paidAt                DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  featuredCredits       Int                        @default(0)
  buyerAddressLine1     String?
  buyerCity             String?
  buyerCompanyName      String?
  buyerEmail            String?
  buyerNip              String?
  buyerPostalCode       String?
  invoiceIssuedAt       DateTime?
  invoiceNumber         String?
  invoicePdfUrl         String?
  invoiceType           BuyerInvoiceType           @default(NONE)
  creditTransactions    ListingCreditTransaction[]
  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([packageType])
}

model Invoice {
  id                    String            @id @default(cuid())
  userId                String
  stripeSessionId       String?           @unique
  stripePaymentIntentId String?           @unique
  stripeCheckoutUrl     String?
  invoiceNumber         String?           @unique
  type                  SalesInvoiceType
  status                InvoiceStatus     @default(PENDING)
  source                InvoiceSource     @default(INTERNAL)
  amountGross           Int
  currency              String            @default("PLN")
  companyName           String?
  nip                   String?
  addressLine1          String?
  addressLine2          String?
  postalCode            String?
  city                  String?
  country               String?           @default("PL")
  invoiceEmail          String?
  itemName              String?
  quantity              Int               @default(1)
  issuedAt              DateTime?
  paidAt                DateTime?
  pdfPath               String?
  pdfFileName           String?
  ksefReferenceNumber   String?
  ksefInvoiceNumber     String?
  ksefSentAt            DateTime?
  ksefAcceptedAt        DateTime?
  ksefErrorMessage      String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  buyerName             String?
  ksefRequired          Boolean           @default(true)
  buyerType             InvoiceBuyerType?
  ksefStatus            KsefStatus        @default(READY)
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([buyerType, createdAt])
  @@index([ksefStatus, createdAt])
  @@index([invoiceNumber])
  @@index([nip])
}

model EmailSendLog {
  id          String        @id @default(cuid())
  type        EmailSendType
  campaignKey String
  email       String
  userId      String?
  sentAt      DateTime      @default(now())
  user        User?         @relation(fields: [userId], references: [id])

  @@unique([type, campaignKey, email])
  @@index([userId])
  @@index([campaignKey])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  imageUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished, createdAt])
}

model CrmIntegration {
  id       String      @id @default(cuid())
  userId   String
  name     String
  provider CrmProvider @default(GALACTICA)
  isActive Boolean     @default(true)

  transportType CrmTransportType @default(FTP)
  feedFormat    CrmFeedFormat    @default(DOMY_PL)

  ftpHost             String?
  ftpPort             Int?    @default(21)
  ftpUsername         String?
  ftpPassword         String?
  ftpRemotePath       String?
  ftpPassive          Boolean @default(true)
  expectedFilePattern String? @default("oferty_*.zip")
  fullImportMode      Boolean @default(true)

  apiKeyHash   String?
  apiKeyPrefix String?
  apiKeyLast4  String?

  lastUsedAt       DateTime?
  lastSyncAt       DateTime?
  lastSuccessAt    DateTime?
  lastErrorAt      DateTime?
  lastErrorMessage String?

  lastImportedOffers   Int @default(0)
  lastCreatedCount     Int @default(0)
  lastUpdatedCount     Int @default(0)
  lastDeactivatedCount Int @default(0)
  lastSkippedCount     Int @default(0)
  lastErrorCount       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerLinks     CrmOfferLink[]
  syncLogs       CrmSyncLog[]
  importJobs     CrmImportJob[]
  processedFiles CrmProcessedFile[]

  @@unique([userId, name])
  @@index([userId])
  @@index([provider])
  @@index([isActive])
  @@index([transportType])
  @@index([feedFormat])
}

model CrmOfferLink {
  id                String    @id @default(cuid())
  integrationId     String
  dzialkaId         String
  externalId        String
  externalUpdatedAt DateTime?
  lastImportedAt    DateTime?
  lastSeenAt        DateTime?
  lastPublishedAt   DateTime?
  lastDeactivatedAt DateTime?
  isActiveInSource  Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  integration CrmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  dzialka     Dzialka        @relation(fields: [dzialkaId], references: [id], onDelete: Cascade)
  syncLogs    CrmSyncLog[]

  @@unique([integrationId, externalId])
  @@index([integrationId])
  @@index([dzialkaId])
  @@index([externalId])
  @@index([isActiveInSource])
  @@index([lastSeenAt])
}

model CrmSyncLog {
  id            String        @id @default(cuid())
  integrationId String
  dzialkaId     String?
  offerLinkId   String?
  externalId    String?
  action        CrmSyncAction
  status        CrmSyncStatus
  message       String?
  payload       Json?
  createdAt     DateTime      @default(now())

  integration CrmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  dzialka     Dzialka?       @relation(fields: [dzialkaId], references: [id], onDelete: SetNull)
  offerLink   CrmOfferLink?  @relation(fields: [offerLinkId], references: [id], onDelete: SetNull)

  @@index([integrationId, createdAt])
  @@index([dzialkaId])
  @@index([offerLinkId])
  @@index([externalId])
  @@index([action, status])
}

model CrmImportJob {
  id            String             @id @default(cuid())
  integrationId String
  integration   CrmIntegration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  status        CrmImportJobStatus @default(PENDING)

  startedAt    DateTime?
  finishedAt   DateTime?
  message      String?
  errorMessage String?

  remoteFileName String?

  importedOffers   Int @default(0)
  createdCount     Int @default(0)
  updatedCount     Int @default(0)
  deactivatedCount Int @default(0)
  skippedCount     Int @default(0)
  errorCount       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([integrationId])
  @@index([status])
  @@index([createdAt])
}

model CrmProcessedFile {
  id             String   @id @default(cuid())
  integrationId  String
  remoteFileName String
  fileSize       Int?
  fileModifiedAt DateTime?
  status         String   @default("SUCCESS")
  importedOffers Int      @default(0)
  createdCount   Int      @default(0)
  updatedCount   Int      @default(0)
  deactivatedCount Int    @default(0)
  skippedCount   Int      @default(0)
  errorCount     Int      @default(0)
  message        String?
  processedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  integration CrmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, remoteFileName])
  @@index([integrationId])
  @@index([status])
  @@index([processedAt])
  @@index([remoteFileName])
}

enum Role {
  USER
  ADMIN
}

enum DzialkaStatus {
  AKTYWNE
  ZAKONCZONE
}

enum DzialkaSourceType {
  MANUAL
  CRM
}

enum ListingCreditSourceType {
  MANUAL
  FREE
  PACKAGE_PURCHASE
  SINGLE_PURCHASE
  ADMIN_GRANT
  FEATURED_BONUS
  FEATURED_USAGE
  CRM_PUBLICATION
}

enum ListingPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum ListingPackageType {
  SINGLE
  PACK_10
  PACK_40
}

enum BuyerInvoiceType {
  NONE
  COMPANY
}

enum InvoiceBuyerType {
  PRIVATE
  COMPANY
}

enum KsefStatus {
  READY
  SENT
  ACCEPTED
  ERROR
}

enum Przeznaczenie {
  INWESTYCYJNA
  BUDOWLANA
  ROLNA
  LESNA
  REKREACYJNA
  SIEDLISKOWA
}

enum LocationMode {
  EXACT
  APPROX
}

enum SprzedajacyTyp {
  PRYWATNIE
  BIURO
}

enum PradStatus {
  BRAK_PRZYLACZA
  PRZYLACZE_NA_DZIALCE
  PRZYLACZE_W_DRODZE
  WARUNKI_PRZYLACZENIA_WYDANE
  MOZLIWOSC_PRZYLACZENIA
}

enum WodaStatus {
  BRAK_PRZYLACZA
  WODOCIAG_NA_DZIALCE
  WODOCIAG_W_DRODZE
  STUDNIA_GLEBINOWA
  MOZLIWOSC_PODLACZENIA
}

enum KanalizacjaStatus {
  BRAK
  MIEJSKA_NA_DZIALCE
  MIEJSKA_W_DRODZE
  SZAMBO
  PRZYDOMOWA_OCZYSZCZALNIA
  MOZLIWOSC_PODLACZENIA
}

enum GazStatus {
  BRAK
  GAZ_NA_DZIALCE
  GAZ_W_DRODZE
  MOZLIWOSC_PODLACZENIA
}

enum SwiatlowodStatus {
  BRAK
  W_DRODZE
  NA_DZIALCE
  MOZLIWOSC_PODLACZENIA
}

enum SalesInvoiceType {
  LISTING_PACKAGE
  FEATURED_PACKAGE
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum InvoiceSource {
  INTERNAL
  KSEF
}

enum EmailSendType {
  REMINDER
}

enum CrmProvider {
  GENERIC
  ASARI
  ESTI_CRM
  IMOX
  GALACTICA
}

enum CrmTransportType {
  API
  FTP
}

enum CrmFeedFormat {
  DOMY_PL
}

enum CrmSyncAction {
  CREATE
  UPDATE
  DEACTIVATE
  REACTIVATE
  SKIP_NO_CREDITS
  DELETE
  ERROR
}

enum CrmSyncStatus {
  SUCCESS
  ERROR
}

enum CrmImportJobStatus {
  PENDING
  RUNNING
  SUCCESS
  ERROR
}
